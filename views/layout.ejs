<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title || "Habit Hero" %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>

<body class="bg-gradient-to-b from-gray-50 to-gray-100 text-gray-800 flex flex-col min-h-screen">

  <!-- ✅ Dynamic Navbar -->
  <%- include('partials/navbar') %>

  <!-- Main Content -->
  <main class="flex-grow">
    <div class="max-w-6xl mx-auto px-4 py-10">
      <%- body %>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-white border-t py-6 text-center text-sm text-gray-600">
    © <%= new Date().getFullYear() %> Habit Hero. Build better habits every day ✨
  </footer>

</body>
</html>