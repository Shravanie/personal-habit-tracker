<header class="bg-gradient-to-r from-indigo-600 to-purple-600 shadow-md">
  <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">

    <!-- Logo -->
    <a href="/" class="text-2xl font-bold text-white tracking-tight">
      Habit Hero 🚀
    </a>

    <!-- Navigation -->
    <nav class="space-x-6 text-white font-medium">

      <% if (!user) { %>
        <a href="/login" class="hover:opacity-80">Login</a>
        <a href="/register" class="hover:opacity-80">Register</a>
      <% } else { %>
        <a href="/dashboard" class="hover:opacity-80">Dashboard</a>
        <a href="/habits" class="hover:opacity-80">Habits</a>
        <a href="/leaderboard" class="hover:opacity-80">Leaderboard</a>
        <a href="/profile" class="hover:opacity-80">Profile</a>
        <a href="/logout" class="hover:opacity-80">Logout</a>
      <% } %>

    </nav>

  </div>
</header>