<div class="max-w-4xl mx-auto p-6">

  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-800">🏆 Leaderboard</h1>
    <p class="text-gray-500 mt-1">Top 10 users based on XP and streak</p>
  </div>

  <!-- Table Card -->
  <div class="bg-white rounded-2xl shadow overflow-hidden">

    <table class="w-full text-left">

      <!-- Table Head -->
      <thead class="bg-gray-100 text-gray-600 text-sm uppercase">
        <tr>
          <th class="px-6 py-3">#</th>
          <th class="px-6 py-3">User</th>
          <th class="px-6 py-3">XP</th>
          <th class="px-6 py-3">Streak</th>
        </tr>
      </thead>

      <!-- Table Body -->
      <tbody class="divide-y">

        <% top.forEach((u, i) => { %>
          <tr class="hover:bg-gray-50">

            <td class="px-6 py-4 font-semibold">
              <%= i + 1 %>
            </td>

            <td class="px-6 py-4">
              <%= u.username %>
            </td>

            <td class="px-6 py-4 text-indigo-600 font-semibold">
              <%= u.xp %>
            </td>

            <td class="px-6 py-4 text-orange-500">
              🔥 <%= (u.streak && u.streak.current) || 0 %> days
            </td>

          </tr>
        <% }) %>

      </tbody>

    </table>

  </div>

</div>