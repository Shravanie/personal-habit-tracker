<div class="max-w-lg mx-auto bg-white rounded-2xl shadow p-8 mt-10">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">Add a New Habit</h1>

  <form action="/habits" method="POST" class="space-y-5">
    <!-- Habit Name -->
    <div>
      <label for="name" class="block text-gray-700 font-medium mb-2">Habit Name</label>
      <input type="text" id="name" name="name" required
             class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" 
             placeholder="e.g., Morning Jog, Meditation" />
    </div>

    <!-- Habit Description -->
    <div>
      <label for="description" class="block text-gray-700 font-medium mb-2">Description (optional)</label>
      <textarea id="description" name="description" rows="3"
                class="w-full px-4 py-2 border rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none" 
                placeholder="Why do you want to build this habit?"></textarea>
    </div>

    <!-- Buttons -->
    <div class="flex justify-between items-center">
      <a href="/habits" 
         class="px-4 py-2 rounded-xl bg-gray-200 text-gray-800 hover:bg-gray-300 transition">
        Cancel
      </a>
      <button type="submit" 
              class="px-5 py-2 rounded-xl bg-indigo-600 text-white font-medium shadow hover:bg-indigo-700 transition">
        Save Habit
      </button>
    </div>
  </form>
</div>
